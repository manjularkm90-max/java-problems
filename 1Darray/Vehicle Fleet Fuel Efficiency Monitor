import java.util.*;

public class FleetEfficiency {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        double[] arr = new double[n];

        double total = 0;
        double max = Double.MIN_VALUE, min = Double.MAX_VALUE;
        int maxIndex = 0, minIndex = 0;

        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextDouble();
            total += arr[i];

            if (arr[i] > max) {
                max = arr[i];
                maxIndex = i + 1;
            }

            if (arr[i] < min) {
                min = arr[i];
                minIndex = i + 1;
            }
        }

        double avg = total / n;
        double threshold = avg * 0.8;

        List<Integer> under = new ArrayList<>();

        for (int i = 0; i < n; i++) {
            if (arr[i] < threshold) {
                under.add(i + 1);
            }
        }

        System.out.println("Fleet Size: " + n);
        System.out.printf("Average Fuel Efficiency: %.2f MPG\n", avg);
        System.out.printf("Most Efficient: %.2f MPG (Vehicle %d)\n", max, maxIndex);
        System.out.printf("Least Efficient: %.2f MPG (Vehicle %d)\n", min, minIndex);
        System.out.println("Underperforming Vehicles: " + under.size());
        System.out.printf("Efficiency Threshold: %.2f MPG\n", threshold);
        System.out.println("Maintenance Priority: " + under);
    }
}
