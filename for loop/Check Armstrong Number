public class Armstrong {
    public static void main(String[] args) {
        int num = 153;
        int temp = num;
        int sum = 0;

        for (; temp != 0; temp /= 10) {
            int digit = temp % 10;
            sum += digit * digit * digit;
        }

        if (sum == num)
            System.out.println("Armstrong");
        else
            System.out.println("Not Armstrong");
    }
}
