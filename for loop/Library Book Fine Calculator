
import java.util.Scanner;
public class Loop14 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        double totalFines = 0.0;
        int booksOverdue = 0;
        for (int i = 1; i <= n; i++) {
            String type = sc.next();
            int daysLate = sc.nextInt();
            double rate = 0.0;
            if (type.equalsIgnoreCase("Regular")) {
                rate = 0.5;
            } else if (type.equalsIgnoreCase("Reference")) {
                rate = 1.0;
            } else if (type.equalsIgnoreCase("Magazine")) {
                rate = 0.25;
            }
            double calculatedFine = rate * daysLate;
            double actualFine = calculatedFine;

            boolean capApplied = false;

            if (daysLate > 0) {
                booksOverdue++;
            }

            totalFines += actualFine;
            System.out.println("Book " + i + ": " + type);
            System.out.println("Days Late: " + daysLate);
            System.out.println("Daily Fine: $" + rate);
            System.out.println("Calculated Fine: $" + calculatedFine);
            System.out.println("Actual Fine: $" + actualFine);
            System.out.println("Cap Applied: " + (capApplied ? "Yes" : "No"));
            System.out.println();
        }

        double averageFine = totalFines / n;
        System.out.println("Total Books: " + n);
        System.out.printf("Total Fines Collected: $%.2f\n", totalFines);
        System.out.println("Books Overdue: " + booksOverdue);
        System.out.printf("Average Fine: $%.2f\n", averageFine);

        sc.close();
    
}
}
