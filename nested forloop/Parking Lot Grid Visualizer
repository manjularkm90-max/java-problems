
import java.util.Scanner;

public class Nesf16 {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int rows = sc.nextInt();
        int cols = sc.nextInt();

        int occupiedSpots = sc.nextInt();

        boolean[][] lot = new boolean[rows][cols];

        for (int i = 0; i < occupiedSpots; i++) {
            int r = sc.nextInt();
            int c = sc.nextInt();
            lot[r][c] = true;
        }

        System.out.println("Parking Lot Grid:");
        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {

                if (lot[i][j]) {
                    System.out.print("[O] ");
                } else {
                    System.out.print("[ ] ");
                }
            }
            System.out.println();
        }

        int totalSpots = rows * cols;
        int vacant = totalSpots - occupiedSpots;

        double rate = ((double) occupiedSpots / totalSpots) * 100;

        System.out.println();
        System.out.println("Total Spots: " + totalSpots);
        System.out.println("Occupied: " + occupiedSpots);
        System.out.println("Vacant: " + vacant);
        System.out.printf("Occupancy Rate: %.2f%%", rate);

    }
