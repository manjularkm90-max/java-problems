
import java.util.Scanner;
public class nesf12 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int size = sc.nextInt();

        System.out.println("Chess Board Pattern:");

        for (int i = 0; i < size; i++) {
            for (int j = 0; j < size; j++) {

                if ((i + j) % 2 == 0) {
                    System.out.print("■ ");
                } else {
                    System.out.print("□ ");
                }

            }
            System.out.println();
        }
    }
}
