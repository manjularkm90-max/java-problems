class Node {
    int data;
    Node next;

    Node(int data) {
        this.data = data;
        this.next = null;
    }
}

public class Main {
    public static void main(String[] args) {
        Node a = new Node(10);
        Node b = new Node(20);

        a.next = b;  // like pointer linking

        System.out.println(a.next.data); // 20
    }
}
