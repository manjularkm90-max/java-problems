import java.util.*;

class Node {
    int val;
    Node next;
    Node(int v) { val = v; }
}

public class Main {

    static Node mergeKLists(Node[] lists) {
        PriorityQueue<Node> pq = new PriorityQueue<>(
            (a, b) -> a.val - b.val
        );

        for (Node node : lists) {
            if (node != null) pq.add(node);
        }

        Node dummy = new Node(0);
        Node tail = dummy;

        while (!pq.isEmpty()) {
            Node min = pq.poll();
            tail.next = min;
            tail = tail.next;

            if (min.next != null) {
                pq.add(min.next);
            }
        }

        return dummy.next;
    }
}
