public class Main {

    static void subsequence(String str, String ans, int index) {

        if(index == str.length()) {
            System.out.println(ans);
            return;
        }

        
        subsequence(str, ans + str.charAt(index), index + 1);
        subsequence(str, ans, index + 1);
    }

    public static void main(String[] args) {
        subsequence("abc", "", 0);
    }
}
