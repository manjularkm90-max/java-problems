
import java.util.Scanner;

public class NumberPattern {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();

        int i = 1;

        System.out.println("Pattern:");

        do {
            int j = 1;

            do {
                System.out.print(i + " ");
                j++;
            } while (j <= i);

            System.out.println();
            i++;

        } while (i <= n);
    }
}
