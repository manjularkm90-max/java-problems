
import java.util.Scanner;

public class FactorialCalculator {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        long result = 1;
        int i = 1;

        while (i <= n) {
            result *= i;
            i++;
        }

        System.out.println("Factorial of " + n + " = " + result);
    }
}
