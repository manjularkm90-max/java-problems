
import java.util.Scanner;

public class Conditional {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        String locationZone = sc.nextLine();
        double parkingHours = sc.nextDouble();
        sc.nextLine();
        String vehicleType = sc.nextLine();
        String membershipStatus = sc.nextLine();

        double baseHourlyRate = 0.0;
        double zonePremiumPercent = 0.0;
        double vehicleSurcharge = 0.0;
        double membershipDiscountPercent = 0.0;
        double totalFee = 0.0;
        boolean dailyCapApplied = false;
        String rateCategory = "";
        if (locationZone.equalsIgnoreCase("Downtown")) {
            baseHourlyRate = 5.0;
            zonePremiumPercent = 50.0;
        } else {
            if (locationZone.equalsIgnoreCase("Business-District")) {
                baseHourlyRate = 4.0;
                zonePremiumPercent = 30.0;
            } else {
                if (locationZone.equalsIgnoreCase("Residential")) {
                    baseHourlyRate = 2.0;
                    zonePremiumPercent = 0.0;
                } else {
                    if (locationZone.equalsIgnoreCase("Airport")) {
                        baseHourlyRate = 6.0;
                        zonePremiumPercent = 60.0;
                    }
                }
            }
        }
        if (vehicleType.equalsIgnoreCase("Motorcycle")) {
            vehicleSurcharge = 0.0;
        } else {
            if (vehicleType.equalsIgnoreCase("Compact")) {
                vehicleSurcharge = 0.0;
            } else {
                if (vehicleType.equalsIgnoreCase("Sedan")) {
                    vehicleSurcharge = 0.0;
                } else {
                    if (vehicleType.equalsIgnoreCase("SUV")) {
                        vehicleSurcharge = 2.0;
                    } else {
                        if (vehicleType.equalsIgnoreCase("Oversized")) {
                            vehicleSurcharge = 5.0;
                        }
                    }
                }
            }
        }
        if (membershipStatus.equalsIgnoreCase("None")) {
            membershipDiscountPercent = 0.0;
        } else {
            if (membershipStatus.equalsIgnoreCase("Monthly")) {
                membershipDiscountPercent = 20.0;
            } else {
                if (membershipStatus.equalsIgnoreCase("Annual")) {
                    membershipDiscountPercent = 30.0;
                } else {
                    if (membershipStatus.equalsIgnoreCase("VIP")) {
                        membershipDiscountPercent = 50.0;
                    }
                }
            }
        }
        double hourlyCost = baseHourlyRate + (baseHourlyRate * zonePremiumPercent / 100);
        hourlyCost += vehicleSurcharge;
        totalFee = hourlyCost * parkingHours;
        totalFee = totalFee - (totalFee * membershipDiscountPercent / 100);
        double dailyCap = 50.0;
        if (totalFee > dailyCap && parkingHours <= 24) {
            totalFee = dailyCap;
            dailyCapApplied = true;
        }

        if (baseHourlyRate <= 2.0) {
            rateCategory = "Standard";
        } else {
            if (baseHourlyRate <= 5.0) {
                rateCategory = "Premium";
            } else {
                rateCategory = "Luxury";
            }
        }
        System.out.println("Location Zone: " + locationZone);
        System.out.println("Parking Duration: " + parkingHours + " hours");
        System.out.println("Vehicle Type: " + vehicleType);
        System.out.println("Membership Status: " + membershipStatus);
        System.out.println("Base Hourly Rate: $" + baseHourlyRate);
        System.out.println("Zone Premium: " + (int)zonePremiumPercent + "%");
        System.out.println("Vehicle Size Surcharge: $" + vehicleSurcharge);
        System.out.println("Membership Discount: " + (int)membershipDiscountPercent + "%");
        System.out.println("Total Parking Fee: $" + totalFee);
        System.out.println("Daily Cap Applied: " + (dailyCapApplied ? "Yes" : "No"));
        System.out.println("Rate Category: " + rateCategory);

    }
}
